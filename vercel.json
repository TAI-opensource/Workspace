{
  "buildCommand": "bash build.sh",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "rm -f tsconfig.json && bun install --ignore-scripts && echo '{\"compilerOptions\":{\"noEmit\":true,\"skipLibCheck\":true,\"strict\":false},\"include\":[]}' > tsconfig.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/proxy/(.*)",
      "destination": "/api/proxy"
    }
  ]
}
